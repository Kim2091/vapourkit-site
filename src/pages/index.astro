---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';

const features = [
  {
    icon: 'chip',
    title: 'Dual backends',
    desc: 'TensorRT (NVIDIA) or DirectML (AMD/Intel/NV).',
  },
  {
    icon: 'eye',
    title: 'Real-time preview',
    desc: 'See results as they process.',
  },
  {
    icon: 'split',
    title: 'Compare viewer',
    desc: 'Built-in side-by-side video comparison.',
  },
  {
    icon: 'grid',
    title: 'Batch processing',
    desc: 'Queue multiple videos with workflows.',
  },
  {
    icon: 'code',
    title: 'Custom filters',
    desc: 'Write VapourSynth filters and chain them.',
  },
  {
    icon: 'save',
    title: 'Templates & workflows',
    desc: 'Save and share .vkfilter and .vkworkflow files.',
  },
];

const screenshots = [
  { caption: 'Main upscale view' },
  { caption: 'Comparison viewer' },
  { caption: 'Batch processor' },
  { caption: 'Filter chain' },
];

const models = [
  { name: 'TFDAT', tag: 'VSR' },
  { name: 'AnimeSharpV4' },
  { name: 'UltraSharpV2' },
];

const sysreqs = [
  { label: 'OS', value: 'Windows 10/11 (x64)' },
  { label: 'RAM', value: '8 GB +' },
  { label: 'Storage', value: '5 GB min · 10 GB recommended' },
  { label: 'GPU', value: '6 GB VRAM + · NVIDIA 16xx (TensorRT) or DX12 (DirectML)' },
];

const base = import.meta.env.BASE_URL;
---

<Layout>
  <!-- Top nav -->
  <header
    class="sticky top-0 z-40 border-b border-vk-border/8 bg-vk-bg/75 backdrop-blur-md"
  >
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3.5">
      <a href={base} class="flex items-center gap-2.5">
        <span class="bg-icon-mark inline-block h-5 w-5 rounded-md"></span>
        <strong class="text-sm">Vapourkit</strong>
      </a>
      <nav class="hidden items-center gap-6 text-sm text-vk-text-muted md:flex">
        <a href="#features" class="hover:text-vk-text transition-colors">Features</a>
        <a href="#tour" class="hover:text-vk-text transition-colors">Screenshots</a>
        <a href="#models" class="hover:text-vk-text transition-colors">Models</a>
        <a href={`${base}introduction`} class="hover:text-vk-text transition-colors">Docs</a>
        <a href="#community" class="hover:text-vk-text transition-colors">Discord</a>
        <button
          id="vk-theme-toggle"
          aria-label="Toggle theme"
          class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-vk-border/10 text-vk-text-muted transition-colors hover:border-vk-border/20 hover:text-vk-text"
        >
          <span data-theme-show="light"><Icon name="moon" size={15} /></span>
          <span data-theme-show="dark" class="hidden"><Icon name="sun" size={15} /></span>
        </button>
        <a
          href="https://ko-fi.com/s/2e5ebd456d"
          target="_blank"
          rel="noopener"
          class="rounded-md border border-vk-brand-purple/35 bg-vk-elevated px-3.5 py-1.5 font-medium text-vk-text transition-colors hover:border-vk-brand-purple/65"
        >
          Download
        </a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden px-6 py-20 lg:py-28 text-center">
      <div
        class="pointer-events-none absolute inset-0"
        style="background: radial-gradient(ellipse 60% 50% at 50% 30%, var(--vk-hero-glow-1), transparent 70%), radial-gradient(ellipse 40% 35% at 50% 30%, var(--vk-hero-glow-2), transparent 70%);"
      >
      </div>
      <div class="relative z-10 mx-auto max-w-3xl">
        <div
          class="mb-5 inline-flex items-center gap-2 rounded-full border border-vk-border/10 bg-vk-surface-2/60 px-3 py-1 text-xs text-vk-text-muted"
        >
          <Icon name="cyan-dot" />
          <span>AI Video Upscaling · Windows</span>
        </div>
        <h1 class="text-4xl font-bold leading-[1.1] tracking-tight text-vk-text sm:text-5xl lg:text-[3rem]">
          Upscale and restore video,<br />
          <span class="font-normal text-vk-text-muted">beautifully.</span>
        </h1>
        <p class="mx-auto mt-5 max-w-xl text-base leading-relaxed text-vk-text-muted">
          Free, open source video upscaling with AI models. Real-time preview,
          side-by-side comparison, batch processing.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a
            href="https://ko-fi.com/s/2e5ebd456d"
            target="_blank"
            rel="noopener"
            class="rounded-lg border border-vk-brand-purple/40 bg-vk-elevated px-6 py-2.5 text-sm font-medium text-vk-text transition-colors hover:border-vk-brand-purple/70"
          >
            Download Free
          </a>
          <a
            href="https://github.com/Kim2091/vapourkit"
            target="_blank"
            rel="noopener"
            class="flex items-center gap-2 rounded-lg border border-vk-border/12 px-6 py-2.5 text-sm text-vk-text transition-colors hover:border-vk-border/25"
          >
            <Icon name="github" size={16} />
            <span>View on GitHub</span>
          </a>
        </div>

        <!-- Hero screenshot -->
        <div class="mx-auto mt-14 max-w-3xl rounded-xl border border-vk-border/8 bg-vk-surface-2 p-1.5">
          <div
            class="flex h-60 items-center justify-center rounded-md bg-vk-bg text-xs text-vk-text-subtle"
          >
            [ App screenshot — vapourkit UI ]
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="border-t border-vk-border/6 px-6 py-16">
      <div class="mx-auto max-w-6xl">
        <div class="mb-9 text-center">
          <div
            class="mb-1.5 text-[11px] uppercase tracking-[0.1em] text-vk-text-subtle"
          >
            Features
          </div>
          <h2 class="text-2xl font-semibold text-vk-text sm:text-[1.625rem]">
            Everything you need to upscale, compare, and ship.
          </h2>
        </div>
        <div
          class="grid grid-cols-1 overflow-hidden rounded-xl border border-vk-border/6 bg-vk-border/6 gap-px sm:grid-cols-2 md:grid-cols-3"
        >
          {
            features.map((f) => (
              <div class="bg-vk-surface-2 p-6">
                <div class="mb-3.5 flex h-8 w-8 items-center justify-center rounded-md border border-vk-brand-cyan/30 bg-vk-brand-cyan/8">
                  <Icon name={f.icon as any} size={16} stroke="var(--sl-color-accent, #06b6d4)" />
                </div>
                <strong class="text-sm text-vk-text">{f.title}</strong>
                <p class="mt-1.5 text-xs leading-relaxed text-vk-text-muted">{f.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Before / After -->
    <section class="px-6 py-16">
      <div class="mx-auto max-w-6xl">
        <div class="mb-7 text-center">
          <div
            class="mb-1.5 text-[11px] uppercase tracking-[0.1em] text-vk-text-subtle"
          >
            Before / After
          </div>
          <h2 class="text-2xl font-semibold text-vk-text sm:text-[1.625rem]">
            See the difference.
          </h2>
        </div>
        <div
          class="flex h-60 items-center justify-center rounded-xl border border-vk-border/8 bg-vk-surface-2 text-xs text-vk-text-subtle"
        >
          [ Interactive before/after image slider ]
        </div>
      </div>
    </section>

    <!-- Tour -->
    <section id="tour" class="border-t border-vk-border/6 px-6 py-16">
      <div class="mx-auto max-w-6xl">
        <div class="mb-7 text-center">
          <div
            class="mb-1.5 text-[11px] uppercase tracking-[0.1em] text-vk-text-subtle"
          >
            Tour
          </div>
          <h2 class="text-2xl font-semibold text-vk-text sm:text-[1.625rem]">
            A look around.
          </h2>
        </div>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          {
            screenshots.map((s) => (
              <div class="flex h-40 items-center justify-center rounded-lg border border-vk-border/8 bg-vk-surface-2 text-[11px] text-vk-text-subtle">
                [ {s.caption} ]
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Models -->
    <section id="models" class="border-t border-vk-border/6 px-6 py-16">
      <div class="mx-auto max-w-6xl">
        <div class="mb-7 text-center">
          <div
            class="mb-1.5 text-[11px] uppercase tracking-[0.1em] text-vk-text-subtle"
          >
            Models
          </div>
          <h2 class="text-2xl font-semibold text-vk-text sm:text-[1.625rem]">
            Bundled models, or bring your own.
          </h2>
        </div>
        <div class="flex flex-wrap justify-center gap-2">
          {
            models.map((m) => (
              <div class="rounded-md border border-vk-border/10 bg-vk-surface-2 px-4 py-2 text-sm text-vk-text">
                {m.name}
                {m.tag && (
                  <span class="ml-2 text-[11px] text-vk-text-subtle">{m.tag}</span>
                )}
              </div>
            ))
          }
          <div
            class="rounded-md border border-dashed border-vk-border/15 px-4 py-2 text-sm text-vk-text-muted"
          >
            + Custom ONNX
          </div>
        </div>
      </div>
    </section>

    <!-- System requirements -->
    <section class="border-t border-vk-border/6 px-6 py-16">
      <div class="mx-auto max-w-6xl">
        <div class="mb-7 text-center">
          <div
            class="mb-1.5 text-[11px] uppercase tracking-[0.1em] text-vk-text-subtle"
          >
            System Requirements
          </div>
          <h2 class="text-2xl font-semibold text-vk-text sm:text-[1.625rem]">
            Hardware needs.
          </h2>
        </div>
        <div
          class="mx-auto max-w-xl rounded-xl border border-vk-border/8 bg-vk-surface-2 p-7 text-sm text-vk-text-muted"
        >
          {
            sysreqs.map((r, i) => (
              <div
                class={`flex justify-between py-2 ${i < sysreqs.length - 1 ? 'border-b border-vk-border/5' : ''}`}
              >
                <span>{r.label}</span>
                <span class="text-vk-text">{r.value}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Community / Discord -->
    <section id="community" class="border-t border-vk-border/6 px-6 py-16 text-center">
      <div
        class="mb-1.5 text-[11px] uppercase tracking-[0.1em] text-vk-text-subtle"
      >
        Community
      </div>
      <h2 class="text-2xl font-semibold text-vk-text sm:text-[1.625rem]">
        Join the Discord.
      </h2>
      <p class="mx-auto mt-3 max-w-md text-sm text-vk-text-muted">
        Share results, get help, request features. The dev and beta testers are active.
      </p>
      <a
        href="https://discord.gg/uYKMn2hGwB"
        target="_blank"
        rel="noopener"
        class="mt-6 inline-flex items-center gap-2 rounded-lg border border-indigo-500/40 bg-vk-surface-2 px-6 py-2.5 text-sm font-medium text-vk-text transition-colors hover:border-indigo-500/70"
      >
        <Icon name="discord" size={16} />
        <span>Join Discord</span>
      </a>
    </section>

    <!-- Support / Ko-fi -->
    <section class="border-t border-vk-border/6 px-6 py-12 text-center">
      <div
        class="mb-1.5 text-[11px] uppercase tracking-[0.1em] text-vk-text-subtle"
      >
        Support
      </div>
      <h2 class="text-xl font-semibold text-vk-text">Vapourkit is free. Tips help.</h2>
      <p class="mx-auto mt-2 max-w-md text-sm text-vk-text-muted">
        Donations fund GPU time and development.
      </p>
      <a
        href="https://ko-fi.com/kim20913944"
        target="_blank"
        rel="noopener"
        class="mt-4 inline-flex items-center gap-2 rounded-lg border border-pink-500/40 px-5 py-2 text-sm text-pink-500 transition-colors hover:border-pink-500/70 dark:text-pink-300"
      >
        <Icon name="coffee" size={14} />
        <span>Ko-fi</span>
      </a>
    </section>

    <!-- Credits footer -->
    <footer
      class="border-t border-vk-border/6 px-6 py-7 text-center text-[11px] text-vk-text-subtle"
    >
      VapourSynth · vs-mlrt · pifroggi · Sirosky · the-database · vs-jetpack · beta testers — GPL 3.0
    </footer>
  </main>

  <!-- Toggle the moon/sun visibility based on theme -->
  <style>
    [data-theme="dark"] [data-theme-show="light"] { display: none; }
    [data-theme="dark"] [data-theme-show="dark"] { display: inline-flex; }
    [data-theme="light"] [data-theme-show="light"] { display: inline-flex; }
    [data-theme="light"] [data-theme-show="dark"] { display: none; }
  </style>
</Layout>
