---
interface Props {
  name:
    | 'chip'
    | 'eye'
    | 'split'
    | 'grid'
    | 'code'
    | 'save'
    | 'github'
    | 'discord'
    | 'download'
    | 'arrow-right'
    | 'coffee'
    | 'sun'
    | 'moon'
    | 'cyan-dot';
  size?: number;
  class?: string;
  stroke?: string;
}

const { name, size = 16, class: className = '', stroke = 'currentColor' } = Astro.props;
---

{
  name === 'chip' && (
    <svg
      width={size}
      height={size}
      viewBox="0 0 24 24"
      fill="none"
      stroke={stroke}
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={className}
    >
      <rect x="4" y="4" width="16" height="16" rx="2" />
      <rect x="9" y="9" width="6" height="6" />
      <path d="M9 2v2M15 2v2M9 20v2M15 20v2M2 9h2M2 15h2M20 9h2M20 15h2" />
    </svg>
  )
}
{
  name === 'eye' && (
    <svg
      width={size}
      height={size}
      viewBox="0 0 24 24"
      fill="none"
      stroke={stroke}
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={className}
    >
      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
      <circle cx="12" cy="12" r="3" />
